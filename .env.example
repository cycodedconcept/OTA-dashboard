# Frontend-safe variables only
VITE_API_BASE_URL=https://zubitechnologies.com/ota_server/api

# Optional: only if you use a Dojah widget/SDK on the client
VITE_DOJAH_PUBLIC_KEY=your_public_key

# Server-only Dojah credentials
# Do not rename these with a VITE_ prefix or they will be exposed to the client bundle.
DOJAH_BASE_URL=https://sandbox.dojah.io
DOJAH_APP_ID=your_app_id
DOJAH_SECRET_KEY=your_secret_key
DOJAH_WEBHOOK_SECRET=your_webhook_secret
